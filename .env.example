# Path to the SQLite database file. In production point this inside a mounted
# volume (e.g. /data/jobs.db) so data survives redeploys.
DB_PATH=/data/jobs.db

# Email for HTTP basic auth (the single login the app accepts).
AUTH_EMAIL=you@example.com

# Password for HTTP basic auth. Use a strong, unique value in production.
AUTH_PASSWORD=change-me
